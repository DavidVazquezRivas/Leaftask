{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Quartz": "Warning",
      "BuildingBlocks": "Information"
    }
  },
  "AllowedHosts": "*",
  "Modules": {
    "Users": {
      "Session": {
        "OAuth": {
          "Google": {
            "ClientId": ""
          }
        },
        "Jwt": {
          "Issuer": "LeaftaskApi",
          "Audience": "LeaftaskApp",
          "SecretKey": "",
          "ExpirationInMinutes": 60,
          "RefreshTokenExpirationInDays": 7
        }
      },
      "Outbox": {
        "IntervalInSeconds": 5,
        "BatchSize": 20
      }
    }
  }
}
