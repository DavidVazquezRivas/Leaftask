{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=leaftask;Username=postgres;Password=password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Quartz": "Warning",
      "BuildingBlocks": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ],
    "AllowCredentials": true
  },
  "Modules": {
    "Users": {
      "Session": {
        "OAuth": {
          "Google": {
            "ClientId": ""
          }
        },
        "Jwt": {
          "Issuer": "LeaftaskApi",
          "Audience": "LeaftaskApp",
          "SecretKey": "",
          "ExpirationInMinutes": 60,
          "RefreshTokenExpirationInDays": 7
        }
      },
      "Outbox": {
        "IntervalInSeconds": 5,
        "BatchSize": 20
      }
    }
  }
}